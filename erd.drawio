        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    %% --- USERS ---\n    NGUOI_DUNG {\n        int id PK\n        string email\n        string mat_khau\n        string ho_ten\n        string sdt\n        string avatar_url\n        date ngay_sinh\n        enum gioi_tinh \&quot;NAM, NU, KHAC\&quot;\n        enum loai_tai_khoan \&quot;ADMIN, MEMBER\&quot;\n        enum trang_thai \&quot;ACTIVE, BLOCKED, UNVERIFIED\&quot;\n        datetime ngay_tao\n        datetime ngay_cap_nhat\n    }\n\n    DIA_CHI {\n        int id PK\n        int nguoi_dung_id FK\n        string ten_nguoi_nhan\n        string sdt_nhan\n        string so_nha_duong\n        string phuong_xa\n        string quan_huyen\n        string tinh_thanh\n        boolean mac_dinh\n    }\n\n    LICH_SU_TIM_KIEM {\n        int id PK\n        int nguoi_dung_id FK\n        string tu_khoa\n        datetime thoi_gian_tim\n    }\n\n    %% --- PRODUCTS &amp; CATEGORIES ---\n    DANH_MUC {\n        int id PK\n        string ten\n        string slug \&quot;URL than thien\&quot;\n        string icon_url\n        int danh_muc_cha_id FK\n        int thu_tu\n        boolean trang_thai\n    }\n\n    SAN_PHAM {\n        int id PK\n        int danh_muc_id FK\n        string ten_san_pham\n        string slug\n        string hang_san_xuat\n        text mo_ta\n        decimal gia_hien_thi\n        float diem_danh_gia\n        enum trang_thai \&quot;CON_BAN, NGUNG_BAN, SAP_RA_MAT, HET_HANG\&quot;\n        boolean noi_bat\n        datetime ngay_tao\n        datetime ngay_cap_nhat\n    }\n\n    PHIEN_BAN_SAN_PHAM {\n        int id PK\n        int san_pham_id FK\n        string sku\n        string ten_phien_ban\n        string mau_sac\n        string dung_luong\n        string ram\n        string cau_hinh\n        decimal gia_ban\n        decimal gia_goc\n        int so_luong_ton\n        enum trang_thai \&quot;CON_HANG, HET_HANG, NGUNG_BAN\&quot;\n    }\n\n    HINH_ANH_SAN_PHAM {\n        int id PK\n        int san_pham_id FK\n        int phien_ban_id FK \&quot;Nullable\&quot;\n        string url_anh\n        string alt_text\n        boolean la_anh_chinh\n        int thu_tu\n    }\n\n    THONG_SO_KY_THUAT {\n        int id PK\n        int san_pham_id FK\n        string ten_thong_so \&quot;Ram, Chip, Pin...\&quot;\n        string gia_tri \&quot;8GB, M1, 5000mAh...\&quot;\n        int thu_tu\n    }\n\n    %% --- PROMOTIONS ---\n    KHUYEN_MAI {\n        int id PK\n        string ten_chuong_trinh\n        enum loai_giam \&quot;PHAN_TRAM, SO_TIEN\&quot;\n        decimal gia_tri_giam\n        decimal giam_toi_da\n        datetime ngay_bat_dau\n        datetime ngay_ket_thuc\n        enum trang_thai \&quot;HOAT_DONG, DA_HET_HAN, TAM_DUNG\&quot;\n    }\n\n    SAN_PHAM_KHUYEN_MAI {\n        int san_pham_id PK, FK\n        int khuyen_mai_id PK, FK\n    }\n\n    MA_GIAM_GIA {\n        int id PK\n        string ma_code\n        string mo_ta\n        enum loai_giam \&quot;PHAN_TRAM, SO_TIEN\&quot;\n        decimal gia_tri_giam\n        decimal giam_toi_da\n        decimal don_toi_thieu\n        int so_luot_da_dung\n        int gioi_han_su_dung\n        datetime ngay_bat_dau\n        datetime ngay_ket_thuc\n        enum trang_thai \&quot;HOAT_DONG, DA_HET_HAN, HET_LUOT\&quot;\n    }\n\n    %% --- FEATURES ---\n    DANH_GIA {\n        int id PK\n        int nguoi_dung_id FK\n        int san_pham_id FK\n        int so_sao\n        text noi_dung\n        datetime ngay_viet\n    }\n\n    YEU_THICH {\n        int nguoi_dung_id PK, FK\n        int san_pham_id PK, FK\n        datetime ngay_them\n    }\n\n    %% --- CART &amp; ORDERS ---\n    GIO_HANG {\n        int id PK\n        int nguoi_dung_id FK \&quot;Nullable\&quot;\n        string session_id \&quot;Cho khach vang lai\&quot;\n        datetime ngay_tao\n        datetime ngay_cap_nhat\n    }\n\n    CHI_TIET_GIO {\n        int id PK\n        int gio_hang_id FK\n        int phien_ban_id FK\n        int so_luong\n    }\n\n    DON_HANG {\n        int id PK\n        string ma_don_hang\n        int nguoi_dung_id FK \&quot;Nullable\&quot;\n        int dia_chi_id FK \&quot;Nullable\&quot;\n        int ma_giam_gia_id FK \&quot;Nullable\&quot;\n        enum trang_thai \&quot;CHO_DUYET, DA_XAC_NHAN, DANG_GIAO, DA_GIAO...\&quot;\n        decimal tong_tien\n        decimal phi_van_chuyen\n        decimal tien_giam_gia\n        decimal tong_thanh_toan\n        text thong_tin_guest \&quot;JSON: ten, sdt, dia chi\&quot;\n        text ghi_chu\n        datetime ngay_giao_du_kien\n        datetime ngay_tao\n        datetime ngay_cap_nhat\n    }\n\n    CHI_TIET_DON {\n        int id PK\n        int don_hang_id FK\n        int phien_ban_id FK\n        int so_luong\n        decimal gia_tai_thoi_diem_mua\n    }\n\n    THANH_TOAN {\n        int id PK\n        int don_hang_id FK\n        int nguoi_duyet_id FK \&quot;Admin ID\&quot;\n        enum phuong_thuc \&quot;COD, CHUYEN_KHOAN, QR, TRA_GOP, VI_DIEN_TU\&quot;\n        decimal so_tien\n        string anh_bien_lai \&quot;URL anh\&quot;\n        enum trang_thai_duyet \&quot;CHO_DUYET, THANH_CONG, THAT_BAI, HOAN_TIEN\&quot;\n        text ghi_chu_duyet\n        datetime ngay_thanh_toan\n        datetime ngay_duyet\n    }\n\n    %% --- RELATIONSHIPS ---\n    NGUOI_DUNG ||--o{ DIA_CHI : so_huu\n    NGUOI_DUNG ||--o{ DON_HANG : dat\n    NGUOI_DUNG ||--o{ DANH_GIA : viet\n    NGUOI_DUNG ||--o{ YEU_THICH : luu\n    NGUOI_DUNG ||--o{ LICH_SU_TIM_KIEM : co\n    NGUOI_DUNG ||--o{ THANH_TOAN : \&quot;admin duyet\&quot;\n    NGUOI_DUNG ||--o{ GIO_HANG : so_huu\n\n    DANH_MUC ||--o{ DANH_MUC : \&quot;co_danh_muc_con\&quot;\n    DANH_MUC ||--o{ SAN_PHAM : thuoc_ve\n    \n    SAN_PHAM ||--o{ PHIEN_BAN_SAN_PHAM : co\n    SAN_PHAM ||--o{ THONG_SO_KY_THUAT : co\n    SAN_PHAM ||--o{ DANH_GIA : nhan\n    SAN_PHAM ||--o{ HINH_ANH_SAN_PHAM : co_anh_chinh\n    SAN_PHAM ||--o{ SAN_PHAM_KHUYEN_MAI : nam_trong\n\n    PHIEN_BAN_SAN_PHAM ||--o{ HINH_ANH_SAN_PHAM : co_anh_rieng\n    \n    KHUYEN_MAI ||--o{ SAN_PHAM_KHUYEN_MAI : ap_dung_cho\n\n    MA_GIAM_GIA ||--o{ DON_HANG : su_dung_trong\n\n    GIO_HANG ||--o{ CHI_TIET_GIO : chua\n    CHI_TIET_GIO }o--|| PHIEN_BAN_SAN_PHAM : chon\n\n    DON_HANG ||--o{ CHI_TIET_DON : gom\n    DON_HANG ||--|| THANH_TOAN : co\n    DON_HANG }o--|| DIA_CHI : giao_den\n    CHI_TIET_DON }o--|| PHIEN_BAN_SAN_PHAM : lay_tu&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="mTj99QUkU7KwFTN2ya50-1">
